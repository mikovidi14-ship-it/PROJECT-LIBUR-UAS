<!DOCTYPE html>
<html lang="id">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title><%= title %> · SIMIP</title>
  <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><text y='.9em' font-size='90'>📦</text></svg>">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="/css/style.css">
</head>
<body>
  <% if (typeof user !== 'undefined' && user) { %>
  <div class="d-flex">
    <nav class="sidebar">
      <div class="sidebar-brand">
        <i class="fa-solid fa-boxes-stacked"></i> SIMIP
      </div>
      <ul class="nav flex-column">
        <% if (user.role === 'pelanggan') { %>
        <li class="nav-item"><a class="nav-link" href="/shop"><i class="fa-solid fa-cart-shopping"></i> Belanja</a></li>
        <li class="nav-item"><a class="nav-link" href="/my-orders"><i class="fa-solid fa-receipt"></i> Pesanan Saya</a></li>
        <li class="nav-item"><a class="nav-link" href="/profile"><i class="fa-solid fa-user"></i> Profil Saya</a></li>
        <% } else { %>
        <li class="nav-item"><a class="nav-link" href="/dashboard"><i class="fa-solid fa-gauge"></i> Dashboard</a></li>
        <li class="nav-item">
          <a class="nav-link d-flex align-items-center justify-content-between" href="/orders">
            <span><i class="fa-solid fa-truck-fast"></i> Pesanan Masuk</span>
            <% if (typeof pendingOrdersCount !== 'undefined' && pendingOrdersCount > 0) { %>
            <span class="badge rounded-pill bg-danger"><%= pendingOrdersCount %></span>
            <% } %>
          </a>
        </li>
        <li class="nav-item"><a class="nav-link" href="/sales"><i class="fa-solid fa-cash-register"></i> Penjualan</a></li>
        <li class="nav-item"><a class="nav-link" href="/customers"><i class="fa-solid fa-users"></i> Pelanggan</a></li>
        <li class="nav-item"><a class="nav-link" href="/products"><i class="fa-solid fa-box"></i> Produk</a></li>
        <li class="nav-item"><a class="nav-link" href="/categories"><i class="fa-solid fa-tags"></i> Kategori</a></li>
        <li class="nav-item"><a class="nav-link" href="/suppliers"><i class="fa-solid fa-truck"></i> Supplier</a></li>
        <li class="nav-item"><a class="nav-link" href="/transactions"><i class="fa-solid fa-right-left"></i> Transaksi Stok</a></li>
        <li class="nav-item"><a class="nav-link" href="/reports"><i class="fa-solid fa-file-lines"></i> Laporan</a></li>
        <li class="nav-item"><a class="nav-link" href="/profile"><i class="fa-solid fa-user"></i> Profil Saya</a></li>
        <% } %>
      </ul>
      <div class="sidebar-user">
        <a href="/profile" class="text-decoration-none d-flex align-items-center gap-2 mb-1">
          <% if (typeof userPhoto !== 'undefined' && userPhoto) { %>
          <img src="<%= userPhoto %>" alt="Foto profil" class="sidebar-avatar">
          <% } else { %>
          <div class="sidebar-avatar sidebar-avatar-placeholder"><i class="fa-solid fa-user"></i></div>
          <% } %>
          <div class="fw-semibold text-white"><%= user.name || user.username %></div>
        </a>
        <div class="chip text-uppercase"><%= user.role %></div>
        <a href="/logout" class="btn btn-sm btn-outline-light mt-2 w-100"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
      </div>
    </nav>
    <main class="content">
      <%- body %>
    </main>
  </div>
  <% } else { %>
    <%- body %>
  <% } %>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  <script src="/js/tilt3d.js"></script>
  <script>
    // Highlight menu sidebar sesuai halaman aktif (mengikuti pola nav-link template)
    document.querySelectorAll('.sidebar .nav-link').forEach(function (link) {
      const path = window.location.pathname;
      const href = link.getAttribute('href');
      if (href && href !== '/' && path.startsWith(href)) {
        link.classList.add('active');
      }
    });

    // Sapaan "Selamat Pagi/Siang/Sore/Malam" berdasarkan jam saat ini, dipakai
    // di banner selamat datang pada halaman Dashboard.
    document.querySelectorAll('[data-greeting-prefix]').forEach(function (el) {
      const hour = new Date().getHours();
      const timeGreeting = hour < 11 ? 'Selamat Pagi' : hour < 15 ? 'Selamat Siang' : hour < 19 ? 'Selamat Sore' : 'Selamat Malam';
      const name = el.getAttribute('data-user-name') || '';
      el.textContent = timeGreeting + (name ? ', ' + name + '!' : '!');
    });
  </script>
</body>
</html>
