<h2 class="mb-4">Kategori</h2>

<div class="row g-3">
  <% if (user.role === 'admin') { %>
  <div class="col-md-4">
    <div class="card card-stat p-3">
      <h6>Tambah Kategori</h6>
      <form method="POST" action="/categories/new">
        <input type="text" name="name" class="form-control mb-2" placeholder="Nama kategori" required>
        <button class="btn btn-primary w-100">Tambah</button>
      </form>
    </div>
  </div>
  <% } %>
  <div class="col-md-<%= user.role === 'admin' ? '8' : '12' %>">
    <div class="card card-stat p-3">
      <table class="table table-hover mb-0">
        <thead><tr><th>Nama Kategori</th><% if (user.role === 'admin') { %><th>Aksi</th><% } %></tr></thead>
        <tbody>
          <% categories.forEach(c => { %>
          <tr>
            <td><%= c.name %></td>
            <% if (user.role === 'admin') { %>
            <td>
              <form action="/categories/<%= c.id %>/delete" method="POST" onsubmit="return confirm('Hapus kategori ini?')">
                <button class="btn btn-sm btn-outline-danger"><i class="fa-solid fa-trash"></i></button>
              </form>
            </td>
            <% } %>
          </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
</div>
